# ─── Entorno ─────────────────────────────────────────
ENVIRONMENT=development

# ─── AI Provider (claude | ollama | bedrock) ─────────
AI_PROVIDER_NAME=claude
ANTHROPIC_API_KEY=tu-api-key-aqui
CLAUDE_CHAT_MODEL=claude-haiku-4-5-20251001
CLAUDE_VISION_MODEL=claude-haiku-4-5-20251001

# Costos estimados (opcional)
# Mantener estos valores actualizados segun la pagina oficial del proveedor.
# Formato por modelo: {"proveedor:modelo":{"input":costo_input_por_1M,"output":costo_output_por_1M}}
# USAGE_PRICING_JSON={"claude:claude-haiku-4-5-20251001":{"input":0.00,"output":0.00}}
# Alternativa simple para un solo modelo activo:
# USAGE_INPUT_COST_PER_MILLION_USD=0.00
# USAGE_OUTPUT_COST_PER_MILLION_USD=0.00

# ─── PostgreSQL ──────────────────────────────────────
POSTGRES_USER=coolagent
POSTGRES_PASSWORD=coolagent_dev
POSTGRES_DB=coolagent
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────
REDIS_PORT=6379

# ─── MinIO (S3 local) ───────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=coolagent

# ─── API ─────────────────────────────────────────────
API_PORT=8000
SECRET_KEY=cambiar-en-produccion-por-algo-seguro
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Ollama (alternativa local) ─────────────────────
